# BalanceIQ - Backend Environment Configuration
# Copy this to .env and adjust values for your environment

APP_NAME=BalanceIQ
APP_ENV=local
DEBUG=true

# Security
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/balanceiq.db
# DATABASE_URL=postgresql://user:password@localhost:5432/balanceiq

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data/storage

# Job Runner (sync for local dev, celery for production)
JOB_RUNNER=sync
# REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:4200"]

# Logging
LOG_LEVEL=DEBUG
